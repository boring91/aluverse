{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Next.js: debug full stack",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "bun",
            "program": "next",
            "args": ["dev"],
            "runtimeArgs": ["--inspect"],
            "skipFiles": ["<node_internals>/**"],
            "cwd": "${workspaceFolder}",
            "serverReadyAction": {
                "killOnServerStop": true,
                "pattern": "- Local:.+(https?://.+)",
                "uriFormat": "%s",
                "webRoot": "${workspaceFolder}"
            }
        }
    ]
}

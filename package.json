{
  "name": "aluverse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "auth:generate": "bunx @better-auth/cli generate --config src/lib/auth.ts",
    "commit-spellcheck": "scripts/commit-spellcheck.sh",
    "commitlint": "commitlint --edit",
    "build": "vite build",
    "check": "prettier --check .",
    "db:generate": "drizzle-kit generate --config ./src/db/drizzle.config.ts",
    "db:introspect": "kysely-codegen --camel-case --out-file ./src/db/types.d.ts",
    "db:migrate": "drizzle-kit migrate --config ./src/db/drizzle.config.ts",
    "db:seed": "bun run scripts/seed-init.ts",
    "db:studio": "drizzle-kit studio --config ./src/db/drizzle.config.ts",
    "dev": "mprocs",
    "dev:app": "vite dev --port 3000",
    "dev:infra": "docker compose -f docker-compose.dev.yml up",
    "format": "prettier --write . && eslint --fix",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "precommit": "sh scripts/precommit.sh",
    "prepare": "husky || true",
    "preview": "vite preview",
    "spellcheck": "cspell \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.1.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "1.168.18",
    "@trpc/client": "^11.7.1",
    "@trpc/server": "^11.7.1",
    "@trpc/tanstack-react-query": "^11.7.1",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "^8.6.0",
    "googleapis": "^169.0.0",
    "input-otp": "^1.4.2",
    "kysely": "^0.28.9",
    "lucide-react": "^0.554.0",
    "nitro": "npm:nitro-nightly@latest",
    "nuqs": "^2.8.4",
    "pg": "^8.16.3",
    "react": "19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.2.0",
    "react-resizable-panels": "^4.6.2",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "superjson": "^2.2.5",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.1.12",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@cspell/eslint-plugin": "^9.8.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/eslint-plugin-query": "^5.100.8",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "baseline-browser-mapping": "^2.9.16",
    "cspell": "^9.4.0",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "husky": "^9.0.11",
    "kysely-codegen": "^0.19.0",
    "mprocs": "^0.9.6",
    "prettier": "^3.7.4",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "8.0.16"
  }
}

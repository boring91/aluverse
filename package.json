{
  "name": "aluverse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "auth:generate": "pnpm dlx @better-auth/cli generate --config lib/auth.ts",
    "auth:seed": "tsx scripts/seed-admin.ts",
    "build": "next build",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config db/drizzle.config.ts",
    "db:introspect": "kysely-codegen --camel-case --out-file ./db/types.d.ts",
    "db:migrate": "drizzle-kit migrate --config db/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config db/drizzle.config.ts",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "prepare": "husky",
    "spellcheck": "cspell \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "start": "next start"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,css,html,yml,yaml,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "1.1.0",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.7.1",
    "@trpc/server": "^11.7.1",
    "@trpc/tanstack-react-query": "^11.7.1",
    "better-auth": "^1.3.34",
    "class-variance-authority": "^0.7.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "^8.6.0",
    "googleapis": "^169.0.0",
    "input-otp": "^1.4.2",
    "kysely": "^0.28.9",
    "lucide-react": "^0.554.0",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.4",
    "pg": "^8.16.3",
    "react": "19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.2.0",
    "react-resizable-panels": "^4.6.2",
    "recharts": "2.15.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.5",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.1.12",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.9.16",
    "cspell": "^9.4.0",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.0.11",
    "kysely-codegen": "^0.19.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.7.4",
    "shadcn": "^3.8.4",
    "sort-package-json": "^3.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
